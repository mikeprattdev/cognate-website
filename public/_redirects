# Cloudflare Pages rewrites. Each block's canonical path is /blocks/<slug>/.
# Specific rules first; splats last.

# Old plugin URLs → new block URLs
/plugins.html     /blocks               301
/plugins/*        /blocks/:splat        200

# Make .html → pretty URL redirects explicit 301 (permanent) so Google
# treats them as "page with redirect" instead of bucketing the bare
# .html copies as alternatives / redirect errors. Cloudflare's default
# behaviour is a 307, which Google flags in Search Console.
/index.html       /                     301
/blocks.html      /blocks               301
/about.html       /about                301
/contact.html     /contact              301
