# Files in this directory that should NOT be uploaded as static assets.
# Pattern syntax matches .gitignore. Keeps the asset bundle small and
# prevents config/source files from being served publicly.

.git
.git/
.gitignore
.assetsignore
.DS_Store

# Config and source for the Worker itself (bundled separately)
wrangler.jsonc
worker.js
.dev.vars
.dev.vars.example

# Local-only scratch
products.json
scripts/
